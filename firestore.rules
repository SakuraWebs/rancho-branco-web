rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - role: string (required, enum: ['admin', 'user']) - Access level
    //   - createdAt: timestamp (optional)
    //
    // Collection: gallery
    // Document ID: auto-generated
    // Fields:
    //   - type: string (required, enum: ['foto', 'video'])
    //   - url: string (required) - Image URL or YouTube ID
    //   - category: string (required, enum: ['casamentos', 'eventos', 'espacos'])
    //   - createdAt: timestamp (required)
    //   - createdBy: string (optional) - Admin UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "enrique.rfm@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidGalleryItem(data) {
      return data.keys().hasAll(['type', 'url', 'category', 'createdAt']) &&
             data.type in ['foto', 'video'] &&
             data.url is string && data.url.size() < 1000 &&
             data.category in ['casamentos', 'eventos', 'espacos'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /gallery/{itemId} {
      allow read: if true; // Public gallery
      allow write: if isAdmin() && isValidGalleryItem(request.resource.data);
    }
  }
}
